{{> head}}
{{> header}}

<main class="container">
  <section class="detail-card">
    <h1>{{title}}</h1>
    <p class="muted">Booking as {{user.name}} ({{user.role}})</p>

    <ul class="meta-list">
      <li><strong>Course:</strong> {{course.title}}</li>
      <li><strong>Level:</strong> {{course.level}}</li>
      <li><strong>Type:</strong> {{course.type}}</li>
      <li><strong>Course dates:</strong> {{course.startDate}} to {{course.endDate}}</li>
      <li><strong>Drop-in available:</strong> {{course.allowDropInText}}</li>
      <li><strong>Sessions shown:</strong> {{sessionsCount}}</li>
    </ul>

    {{#hasSessions}}
    <section class="table-wrap">
      <table>
        <thead>
          <tr>
            <th>Start</th>
            <th>End</th>
            <th>Remaining spaces</th>
          </tr>
        </thead>
        <tbody>
          {{#sessions}}
          <tr>
            <td>{{start}}</td>
            <td>{{end}}</td>
            <td>{{remaining}}</td>
          </tr>
          {{/sessions}}
        </tbody>
      </table>
    </section>
    {{/hasSessions}}

    <form method="post" action="{{action}}">
      <button class="btn primary" type="submit">
        {{#isSessionBooking}}Confirm session booking{{/isSessionBooking}}
        {{^isSessionBooking}}Confirm course booking{{/isSessionBooking}}
      </button>
      <a class="btn" href="/courses/{{course.id}}">Cancel</a>
    </form>
  </section>
</main>

{{> footer}}